{
  "name": "agent-voice-dictation",
  "version": "0.1.0",
  "description": "Lean browser recording, speech-to-text clients, and OpenRouter transcript polish for agent composer dictation.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./composer": {
      "types": "./dist/composer/index.d.ts",
      "default": "./dist/composer/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "default": "./dist/env/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:core": "vitest run --project core",
    "test:system": "vitest run --project system",
    "test:live": "vitest run --config vitest.live.config.ts --passWithNoTests",
    "test:stt:live": "npm run test:live",
    "test:coverage": "vitest run --coverage",
    "test:package": "npm run build && node scripts/test-package.mjs",
    "test:contract": "node scripts/check-test-contract.mjs",
    "check": "npm run test:contract && npm run typecheck && npm test && npm run test:package"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  },
  "license": "MIT",
  "dependencies": {
    "ws": "^8.20.0"
  }
}
